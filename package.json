{
  "name": "expensio",
  "version": "1.0.0",
  "private": true,
  "description": "Expensio - Personal finance management + bill splitting (MERN stack)",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "cd client && pnpm dev",
    "dev:server": "cd server && pnpm dev",
    "install:all": "cd client && pnpm install && cd ../server && pnpm install"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "sharp": "^0.35.3"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
